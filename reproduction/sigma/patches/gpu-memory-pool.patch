diff --git a/GPU-MPC/utils/gpu_mem.cu b/GPU-MPC/utils/gpu_mem.cu
index f241ad4..9839ddd 100644
--- a/GPU-MPC/utils/gpu_mem.cu
+++ b/GPU-MPC/utils/gpu_mem.cu
@@ -20,6 +20,7 @@
 // SOFTWARE.
 
 #include <chrono>
+#include <cstdlib>
 
 #include <cuda.h>
 #include <cuda_runtime.h>
@@ -47,7 +48,21 @@ extern "C" void initGPUMemPool()
     uint64_t threshold = UINT64_MAX;
     checkCudaErrors(cudaMemPoolSetAttribute(mempool, cudaMemPoolAttrReleaseThreshold, &threshold));
     uint64_t *d_dummy_ptr;
-    uint64_t bytes = 40 * (1ULL << 30);
+    // Keep the artifact's 40 GiB default, but allow smaller pools when the
+    // code is run on a shared GPU server. This allocation only warms the
+    // CUDA async memory pool; it does not change protocol semantics.
+    uint64_t pool_gib = 40;
+    if (const char *value = std::getenv("SIGMA_GPU_POOL_GB"))
+    {
+        char *end = nullptr;
+        const auto parsed = std::strtoull(value, &end, 10);
+        if (end != value && *end == '\0')
+            pool_gib = parsed;
+    }
+    uint64_t bytes = pool_gib * (1ULL << 30);
+    printf("warming GPU memory pool with %lu GiB\n", pool_gib);
+    if (bytes == 0)
+        return;
     checkCudaErrors(cudaMallocAsync(&d_dummy_ptr, bytes, 0));
     checkCudaErrors(cudaFreeAsync(d_dummy_ptr, 0));
     uint64_t reserved_read, threshold_read;
